<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8" />
  </startup>
  <appSettings>
    <!-- ===== 웹서버 ===== -->
    <add key="PORT" value="8731" />
    <!-- BIND: localhost = 이 PC만 / lan = 사내망 다른 PC도 접속 (관리자/URL ACL 필요) -->
    <add key="BIND" value="localhost" />

    <!-- ===== AVEVA Marine 환경변수 (Standalone.Start 용 — 실제 환경에 맞게) ===== -->
    <!-- ★ Marine 모듈 번호: 78 은 E3D Model. AM Outfitting 모듈 번호로 변경 (marine-probe.ps1 참고) -->
    <add key="MODULE_NUMBER" value="AAAA" />
    <add key="projects_dir"      value="C:\AVEVA\Marine\Projects" />
    <add key="AVEVA_DESIGN_USER" value="C:\AVEVA\Marine\USERDATA" />
    <add key="PMLLIB"            value="C:\AVEVA\Marine\PMLLIB" />
    <!-- 프로젝트 코드별 경로 (키 = 프로젝트코드+000). 예: AAAA000 -->
    <add key="AAAA000"           value="C:\AVEVA\Marine\Projects\AAAA" />
    <!-- ※ 로그인 값(PROJECT/USER/PASSWORD/MDB)은 웹 화면(① 탭)에서 입력합니다. 여기 둘 필요 없음. -->
  </appSettings>
</configuration>
