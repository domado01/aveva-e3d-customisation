<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8" />
  </startup>
  <appSettings>
    <!-- ===== 웹서버 ===== -->
    <add key="PORT" value="8731" />
    <!-- BIND: localhost = 이 PC만 / lan = 사내망 다른 PC도 접속 (관리자/URL ACL 필요) -->
    <add key="BIND" value="localhost" />

    <!-- ===== AVEVA 환경변수 (Standalone.Start 용 — E3D 환경에 맞게) ===== -->
    <add key="MODULE_NUMBER" value="78" />
    <add key="projects_dir"      value="C:\Users\Public\Documents\AVEVA\Training3.0\Projects" />
    <add key="AVEVA_DESIGN_USER" value="C:\Users\Public\Documents\AVEVA\Training3.0\USERDATA" />
    <add key="PMLLIB"            value="C:\Users\Public\Documents\AVEVA\Training3.0\PMLLIB" />
    <add key="TRA000"            value="C:\Users\Public\Documents\AVEVA\Training3.0\Projects\TRA" />
    <!-- ※ 로그인 값(PROJECT/USER/PASSWORD/MDB)은 웹 화면에서 입력합니다. 여기 둘 필요 없음. -->
  </appSettings>
</configuration>
