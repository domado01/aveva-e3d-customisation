<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8" />
  </startup>
  <!-- ★ 설정값은 공용 파일 leaf-settings.config 한 곳에서 관리 (exe 옆에서 읽음).
       로그인(PROJECT/USER/PASSWORD/MDB)은 웹 화면에서 입력하므로, 이 파일에선
       MODULE_NUMBER/환경변수/PORT/BIND 를 사용합니다. -->
  <appSettings file="leaf-settings.config" />
</configuration>
