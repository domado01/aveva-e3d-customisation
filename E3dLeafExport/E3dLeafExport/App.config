<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8" />
  </startup>

  <!-- ======================================================================
       ★ 설정값은 공용 파일 leaf-settings.config 한 곳에서 관리합니다.
         (이 file= 속성으로 exe 옆의 leaf-settings.config 를 읽어옵니다)
         값을 바꾸려면 leaf-settings.config 만 열어서 수정하세요.
       ====================================================================== -->
  <appSettings file="leaf-settings.config" />
</configuration>
