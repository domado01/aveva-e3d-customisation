<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8" />
  </startup>

  <!-- ======================================================================
       이 파일의 모든 키는 빌드 시 E3dLeafExport.exe.config 로 복사되어
       프로그램이 읽습니다. (매뉴얼의 TrainingStandalone.exe.config 와 동일 역할)

       ★ 가장 확실한 방법:
         AVEVA 교육용 TrainingStandalone 프로젝트의 app.config 에 들어있는
         환경변수 키들을 그대로 이 <appSettings> 안에 복사해 넣으세요.
         (projects_dir, AVEVA_DESIGN_USER, PMLLIB, 그리고 프로젝트코드000 등)
       ====================================================================== -->
  <appSettings>
    <!-- ===== 로그인/프로젝트 정보 (필수) ===== -->
    <add key="PROJECT"  value="TRA" />          <!-- 프로젝트 코드 (예: TRA) -->
    <add key="USER"     value="SYSTEM" />       <!-- 사용자 -->
    <add key="PASSWORD" value="XXXXXX" />       <!-- 비밀번호 -->
    <add key="MDB"      value="MAC-MDB" />      <!-- MDB 이름 -->
    <add key="MODULE_NUMBER" value="78" />      <!-- 78 = Model 모듈 -->

    <!-- ===== AVEVA E3D 환경변수 (E3D 환경에 맞게 수정) ===== -->
    <add key="projects_dir"      value="C:\Users\Public\Documents\AVEVA\Training3.0\Projects" />
    <add key="AVEVA_DESIGN_USER" value="C:\Users\Public\Documents\AVEVA\Training3.0\USERDATA" />
    <add key="PMLLIB"            value="C:\Users\Public\Documents\AVEVA\Training3.0\PMLLIB" />
    <!-- 프로젝트 코드별 데이터 경로 (예: TRA000 = TRA 프로젝트 경로) -->
    <add key="TRA000"            value="C:\Users\Public\Documents\AVEVA\Training3.0\Projects\TRA" />

    <!-- ===== 탐색/출력 옵션 (선택) ===== -->
    <!-- START_ELEMENT 를 비우면 MDB 안의 모든 SITE 부터 탐색.
         특정 요소만 뽑으려면 이름 지정 (예: /SITE-EQUIPMENT-AREA01) -->
    <add key="START_ELEMENT" value="" />
    <!-- 비우면 exe 옆에 E3D_Leaf_Export_날짜시간.txt 로 자동 생성 -->
    <add key="OUTPUT_FILE" value="" />
  </appSettings>
</configuration>
