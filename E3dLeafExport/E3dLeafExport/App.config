<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8" />
  </startup>

  <!-- ======================================================================
       이 파일의 모든 키는 빌드 시 E3dLeafExport.exe.config 로 복사되어
       프로그램이 읽습니다. (매뉴얼의 TrainingStandalone.exe.config 와 동일 역할)

       ★ 가장 확실한 방법:
         AVEVA 교육용 TrainingStandalone 프로젝트의 app.config 에 들어있는
         환경변수 키들을 그대로 이 <appSettings> 안에 복사해 넣으세요.
         (projects_dir, AVEVA_DESIGN_USER, PMLLIB, 그리고 프로젝트코드000 등)
       ====================================================================== -->
  <appSettings>
    <!-- ===========================================================
         ★ 여기 value="AAA" 부분만 실제 값으로 바꾸세요 (메모장으로 열기)
            value 뒤 따옴표 " " 사이의 AAA 만 교체하면 됩니다.
         =========================================================== -->
    <add key="PROJECT"  value="AAA" />          <!-- 프로젝트 코드(번호) -->
    <add key="USER"     value="AAA" />          <!-- 사용자 이름 -->
    <add key="PASSWORD" value="AAA" />          <!-- 비밀번호. 비번 없으면 value="" 로 비우세요 -->
    <add key="MDB"      value="AAA" />          <!-- MDB 이름 -->
    <add key="MODULE_NUMBER" value="AAA" />     <!-- AM Outfitting 모듈 번호 (78 아님, marine-probe 로 확인) -->

    <!-- ===== AVEVA Marine 환경변수 (실제 환경에 맞게 — marine-probe.ps1 출력 참고) ===== -->
    <add key="projects_dir"      value="C:\AVEVA\Marine\Projects" />
    <add key="AVEVA_DESIGN_USER" value="C:\AVEVA\Marine\USERDATA" />
    <add key="PMLLIB"            value="C:\AVEVA\Marine\PMLLIB" />
    <!-- 프로젝트 코드별 데이터 경로 (키 이름 = 프로젝트코드+000). 예: AAAA000 -->
    <add key="AAAA000"           value="C:\AVEVA\Marine\Projects\AAAA" />

    <!-- ===== 탐색/출력 옵션 (선택) ===== -->
    <!-- START_ELEMENT 비우면 모든 SITE 부터 탐색. Outfitting 은 SITE/ZONE 구조라 그대로 동작.
         특정 요소만: 이름 지정 (예: /SITE-...) -->
    <add key="START_ELEMENT" value="" />
    <!-- 비우면 exe 옆에 E3D_Leaf_Export_날짜시간.txt 로 자동 생성 -->
    <add key="OUTPUT_FILE" value="" />
  </appSettings>
</configuration>
