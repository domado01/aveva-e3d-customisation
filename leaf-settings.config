<!-- ============================================================
     ★ 공용 설정 파일 — 이 파일 하나만 고치면 콘솔/웹 양쪽에 적용됩니다.
        value="AAA" 의 AAA 만 실제 값으로 바꾸세요.
        (콘솔/웹의 App.config 가 이 파일을 file= 로 불러옵니다)
     ============================================================ -->
<appSettings>
  <!-- ===== 로그인/프로젝트 (콘솔판에서 사용. 웹판은 브라우저에서 입력) ===== -->
  <add key="PROJECT"  value="AAA" />     <!-- 프로젝트 코드(번호) -->
  <add key="USER"     value="AAA" />     <!-- 사용자 -->
  <add key="PASSWORD" value="AAA" />     <!-- 비밀번호 (없으면 value="") -->
  <add key="MDB"      value="AAA" />     <!-- MDB 이름 -->

  <!-- ===== 모듈/환경 (콘솔+웹 공통) ===== -->
  <add key="MODULE_NUMBER" value="AAA" />     <!-- AM Outfitting 모듈 번호 (marine-probe 로 확인) -->
  <add key="projects_dir"      value="C:\AVEVA\Marine\Projects" />
  <add key="AVEVA_DESIGN_USER" value="C:\AVEVA\Marine\USERDATA" />
  <add key="PMLLIB"            value="C:\AVEVA\Marine\PMLLIB" />
  <add key="AAA000"            value="C:\AVEVA\Marine\Projects\AAA" />  <!-- 키이름 = 프로젝트코드+000 -->

  <!-- ===== 웹서버 (웹판) ===== -->
  <add key="PORT" value="8731" />
  <add key="BIND" value="localhost" />        <!-- localhost = 이 PC만 / lan = 사내망 -->

  <!-- ===== 탐색/출력 (콘솔판, 선택) ===== -->
  <add key="START_ELEMENT" value="" />        <!-- 비우면 전체 SITE -->
  <add key="OUTPUT_FILE"   value="" />        <!-- 비우면 exe 옆 자동생성 -->
</appSettings>
